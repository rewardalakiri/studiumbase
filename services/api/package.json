    "@repo/supabase-config": "*",
    "sb-database": "*",
    "@trpc/server": "^11.4.2",
    "superjson": "2.2.2"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "eslint": "^9.29.0",
    "typescript": "^5.8.2"
  }
}